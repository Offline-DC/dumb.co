{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dumb Down Signin",
  "version": "0.1.0",
  "identifier": "community.offline.dumbdown.gsignin",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Dumb Down Signin",
        "width": 540,
        "height": 660,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
